---
import { Icon } from 'astro-icon/components';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Price } from '~/types';

const { title, subtitle, tagline, prices = [], classes = {}, ...rest } = Astro.props;
---

<WidgetWrapper {...rest} id="pricing" classes={{ container: 'max-w-7xl scroll-mt-16', ...classes.container }} hasBackground>
  <Headline {title} {subtitle} {tagline} classes={{ headline: 'max-w-3xl' }}>
    <slot name="title" slot="title" />
    <slot name="subtitle" slot="subtitle" />
  </Headline>
  
  <div class:list={['gap-8', { 'flex justify-center': prices.length === 1, 'grid sm:grid-cols-2 lg:grid-cols-3': prices.length > 1 }, classes?.grid]}>
    {prices.map((price) => (
        <div class:list={['relative overflow-visible flex flex-col rounded-lg border-2 p-8 text-center shadow-lg', { 'border-primary': price.hasRibbon, 'border-gray-200 dark:border-slate-800': !price.hasRibbon, 'w-full max-w-lg': prices.length === 1 }]}>
          <h3 class="text-2xl font-bold">{price.title}</h3>
          {price.subtitle && <p class="mt-4 text-muted">{price.subtitle}</p>}
          <div class="mt-8 flex-1">
            <div class="flex items-end justify-center">
              <span class="text-5xl font-bold tracking-tight">${price.price}</span>
              <span class="ml-1 text-xl font-medium text-muted">/{price.period}</span>
            </div>
            <ul role="list" class="mt-8 space-y-4 text-left">
              {price.items.map((item) => (
                <li class="flex items-start">
                  <Icon name="tabler:circle-check" class="w-6 h-6 text-primary" />
                  <p class="ml-3 text-base text-muted">{item.description}</p>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="mt-8">
            <form action="https://www.paypal.com/cgi-bin/webscr" method="post" target="_top">
                <input type="hidden" name="cmd" value="_xclick" />
                <input type="hidden" name="business" value="ZFG89TK2KESFG" />
                <input type="hidden" name="item_name" value="SkinTestimonial QR Review Engine Forever Plan" />
                <input type="hidden" name="item_number" value="STFP99" />
                <input type="hidden" name="amount" value="99.00" />
                <input type="hidden" name="currency_code" value="USD" />
                <input type="hidden" name="no_shipping" value="1" />
                <div class="text-left mb-3">
                    <label class="block text-sm font-medium mb-1 dark:text-gray-300">Your Name</label>
                    <input type="hidden" name="on0" value="Customer Name" />
                    <input type="text" name="os0" required class="w-full px-4 py-2 border border-gray-300 rounded-lg dark:bg-slate-900" placeholder="Full Name" />
                </div>
                <div class="text-left mb-6">
                    <label class="block text-sm font-medium mb-1 dark:text-gray-300">Clinic Name</label>
                    <input type="hidden" name="on1" value="Clinic Name" />
                    <input type="text" name="os1" required class="w-full px-4 py-2 border border-gray-300 rounded-lg dark:bg-slate-900" placeholder="Clinic Business Name" />
                </div>
                <button type="submit" class="w-full py-3 px-4 bg-green-600 hover:bg-green-700 text-white font-bold rounded-lg shadow-md transition duration-200">
                  {price.callToAction?.text || 'Get Forever Plan - $99'}
                </button>
                <p class="text-xs text-muted mt-2 uppercase tracking-tighter">Secure Checkout</p>
            </form>
          </div>
        </div>
    ))}
  </div>
</WidgetWrapper>
